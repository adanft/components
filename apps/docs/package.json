{
  "name": "components-docs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm generate:highlighted-code && pnpm exec vite",
    "build": "pnpm generate:highlighted-code && pnpm typecheck && pnpm exec vite build",
    "generate:highlighted-code": "node scripts/generate-highlighted-code.mjs",
    "preview": "pnpm exec vite preview",
    "test": "pnpm generate:highlighted-code && pnpm exec vitest run --config vitest.config.ts",
    "typecheck": "pnpm exec tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@adanft/ui": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
