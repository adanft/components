{
  "name": "@adanft/ui",
  "version": "0.1.0-beta.2",
  "description": "Reusable React UI components with a Tailwind-driven design system contract.",
  "license": "MIT",
  "homepage": "https://adanft.github.io/components",
  "repository": {
    "type": "git",
    "url": "https://github.com/adanft/components.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/adanft/components/issues"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "tailwindcss"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./styles.css"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./styles.css": "./dist/styles.css"
    }
  },
  "scripts": {
    "build": "pnpm typecheck && pnpm exec vite build && pnpm exec tsc -p tsconfig.build.json && node scripts/copy-styles.mjs",
    "prepack": "pnpm build",
    "test": "pnpm exec vitest run --config vitest.config.ts",
    "typecheck": "pnpm exec tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "lucide-react": "^1.8.0",
    "simplebar-react": "^3.3.2",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
