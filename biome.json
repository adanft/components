{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/dist",
      "!**/dist-lib",
      "!**/dist-ssr",
      "!**/node_modules",
      "!**/coverage"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSameLine": true,
      "jsxQuoteStyle": "double"
    }
  },
  "overrides": [
    {
      "includes": ["**/src/docs/**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "correctness": {},
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "../components": "Import from lib/ instead.",
                  "../../components": "Import from lib/ instead.",
                  "../helpers": "Import from lib/ instead.",
                  "../../helpers": "Import from lib/ instead.",
                  "../hooks": "Import from lib/ instead.",
                  "../../hooks": "Import from lib/ instead.",
                  "../pages": "Import from lib/ instead.",
                  "../../pages": "Import from lib/ instead."
                }
              }
            }
          }
        }
      }
    }
  ]
}
