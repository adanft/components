{
  "homepage": "https://adanft.github.io/components",
  "name": "components-workspace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --dir apps/docs dev",
    "build": "pnpm typecheck && pnpm build:packages && pnpm build:docs",
    "build:packages": "pnpm --dir packages/ui build",
    "build:docs": "pnpm --dir apps/docs build",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "preview": "pnpm --dir apps/docs preview",
    "test": "pnpm exec vitest run src/__tests__ && pnpm --recursive --if-present test",
    "typecheck": "tsc -b --pretty false",
    "validate:boundaries": "node scripts/validate-docs-imports.mjs",
    "validate:pack-contract": "node scripts/verify-pack-contract.mjs",
    "validate:semantic-tokens": "node scripts/validate-semantic-tokens.mjs",
    "validate": "pnpm check && pnpm typecheck && pnpm test && pnpm validate:boundaries && pnpm validate:pack-contract && pnpm validate:semantic-tokens && pnpm build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "changeset publish --tag latest",
    "release:latest": "pnpm validate:pack-contract && pnpm --dir packages/ui build && pnpm release",
    "release:beta": "pnpm release:latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.4"
  }
}
