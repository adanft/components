{
  "homepage": "https://adanft.github.io/components",
  "name": "components",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite --config vite.docs.config.ts",
    "build": "pnpm typecheck && pnpm build:docs && pnpm build:lib",
    "build:docs": "vite build --config vite.docs.config.ts",
    "build:lib": "vite build --config vite.lib.config.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "preview": "vite preview --config vite.docs.config.ts",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "validate:boundaries": "node scripts/validate-docs-imports.mjs",
    "validate:semantic-tokens": "node scripts/validate-semantic-tokens.mjs",
    "validate": "pnpm lint && pnpm typecheck && pnpm validate:boundaries && pnpm validate:semantic-tokens && pnpm build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.11.0",
    "shiki": "^3.22.0",
    "simplebar-react": "^3.3.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.0"
  }
}
