{
  "homepage": "https://adanft.github.io/components",
  "name": "components",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite --config vite.docs.config.ts",
    "build": "pnpm typecheck && pnpm build:docs && pnpm build:lib",
    "build:docs": "vite build --config vite.docs.config.ts",
    "build:lib": "vite build --config vite.lib.config.ts",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "preview": "vite preview --config vite.docs.config.ts",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "validate:boundaries": "node scripts/validate-docs-imports.mjs",
    "validate:semantic-tokens": "node scripts/validate-semantic-tokens.mjs",
    "validate": "pnpm check && pnpm typecheck && pnpm validate:boundaries && pnpm validate:semantic-tokens && pnpm build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "shiki": "^4.0.2",
    "simplebar-react": "^3.3.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.x",
    "lucide-react": "^1.x"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "lucide-react": "^1.7.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
